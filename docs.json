{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AXTL Docs",
  "colors": {
    "primary": "#8b5cf6",
    "light": "#fbfcff",
    "dark": "#00081a"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "concepts/what-is-axtl",
              "concepts/core-concepts",
              "concepts/generation-lifecycle"
            ]
          },
          {
            "group": "Build with AXTL",
            "pages": [
              "guides/create-a-backend",
              "guides/deploy-a-backend",
              "guides/invoke-a-backend",
              "guides/manage-api-keys"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication",
              "api-reference/errors"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/glossary",
              "reference/limits"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "AXTL",
          "href": "https://axtl.dev",
          "icon": "rocket"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open AXTL",
      "href": "https://axtl.dev"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
